{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user/warga of the application.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "nama": { "type": "string" },
        "alamat": { "type": "string" },
        "noHp": { "type": "string" },
        "status": { "type": "string" },
        "umur": { "type": "number", "minimum": 0 },
        "role": { "type": "string", "enum": ["warga", "admin", "bendahara"] },
        "members": {
          "type": "array",
          "items": { "type": "object" }
        },
        "photo": { "type": "string" }
      },
      "required": ["username", "nama", "role"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user notification.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "time": { "type": "string" },
        "read": { "type": "boolean" },
        "toUserId": { "type": "string" }
      },
      "required": ["title", "message", "time"]
    },
    "AppResource": {
      "title": "App Resource",
      "description": "Generic resource for surat, laporan, acara, umkm, kas, iuran, darurat, media",
      "type": "object",
      "properties": {
        "createdAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Notifications."
    },
    "/surat/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Surat requests" },
    "/laporan/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Laporan warga" },
    "/acara/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Acara kegiatan" },
    "/umkm/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "UMKM warga" },
    "/kas/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Kas entries" },
    "/iuran/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Iuran entries" },
    "/darurat/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Kontak darurat" },
    "/media/{docId}": { "schema": { "$ref": "#/entities/AppResource" }, "description": "Media uploads" }
  }
}
